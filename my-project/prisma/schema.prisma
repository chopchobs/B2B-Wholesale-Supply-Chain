generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- User & RBAC Section ---

enum Role {
  ADMIN
  MERCHANT
  VIP_CLIENT
  USER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          Role      @default(USER)
  isActive      Boolean   @default(true) // ซ่อน User ที่ถูกแบนได้
  
  managedShops  Shop[]    @relation("ShopOwner")
  orders        Order[]

  // Phase 13: ลูกค้า B2B ผูก 1:1 กับ User
  customerProfile CustomerProfile?

  // Phase 14: Notifications
  notifications Notification[]

  // Phase 15: User & Role Management
  approvals        UserApproval[] @relation("UserApprovals")
  reviewedApprovals UserApproval[] @relation("ApprovalReviewer")
  auditLogs        AuditLog[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Shop {
  id          String    @id @default(cuid())
  name        String
  description String?
  isActive    Boolean   @default(true)
  
  ownerId     String
  owner       User      @relation("ShopOwner", fields: [ownerId], references: [id])
  products    Product[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// --- Product & Tiered Pricing Section ---

model Product {
  id          String      @id @default(cuid())
  sku         String      @unique
  name        String
  description String?     @db.Text
  basePrice   Decimal     @db.Decimal(12, 2)
  moq         Int         @default(1)
  stock       Int         @default(0)
  isActive    Boolean     @default(true) // Soft delete สินค้าได้
  
  shopId      String
  shop        Shop        @relation(fields: [shopId], references: [id])
  
  priceTiers  PriceTier[]
  orderItems  OrderItem[]
  
  category    Category?   @relation(fields: [categoryId], references: [id])
  categoryId  String?

  // Phase 9: เชื่อมกับ InventoryItem แบบ 1:1
  inventory   InventoryItem?

  // Phase 12: line items ใน PurchaseOrder
  purchaseOrderItems PurchaseOrderItem[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([shopId])
  @@index([sku])
  @@index([categoryId])
}

model PriceTier {
  id          String   @id @default(cuid())
  minQuantity Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  targetRole  Role     @default(VIP_CLIENT) 
  isActive    Boolean  @default(true) // เปิด/ปิด โปรโมชั่นขั้นบันไดได้
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// --- Category & Order Section ---

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  isActive    Boolean   @default(true)
  products    Product[]
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  totalAmount Decimal     @db.Decimal(12, 2)
  status      OrderStatus @default(PENDING)

  items       OrderItem[]

  // Phase 11: Invoice 1:1
  invoice     Invoice?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  subTotal  Decimal  @db.Decimal(12, 2)
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// --- Inventory Management Section (Phase 9) ---

model InventoryItem {
  id            String   @id @default(cuid())
  // ผูก 1:1 กับ Product ผ่าน productId
  productId     String   @unique
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // ปริมาณคงเหลือปัจจุบัน
  quantity      Int      @default(0)
  // เกณฑ์เตือนสต็อกต่ำ
  lowStockThreshold Int  @default(10)
  // คลัง / ตำแหน่งจัดเก็บ
  location      String   @default("MAIN-WH")

  transactions  InventoryTransaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([location])
}

enum InventoryTransactionType {
  RESTOCK
  SALE
  ADJUSTMENT
  RETURN
}

model InventoryTransaction {
  id          String   @id @default(cuid())

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  type        InventoryTransactionType
  // quantityDelta: บวก = เพิ่ม, ลบ = ลด (ADJUSTMENT/SALE ใช้ค่าลบได้)
  quantityDelta Int
  note        String?

  createdAt   DateTime @default(now())

  @@index([inventoryItemId])
  @@index([type])
  @@index([createdAt])
}

// --- Invoice & Billing Section (Phase 11) ---

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CREDIT
  CASH
}

model Invoice {
  id            String          @id @default(cuid())
  // เลขที่ใบแจ้งหนี้รูปแบบ INV-YYYYMM-XXXX
  invoiceNumber String          @unique

  // ผูก 1:1 กับ Order
  orderId       String          @unique
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status        InvoiceStatus   @default(DRAFT)
  issuedAt      DateTime        @default(now())
  // net 30 ตั้งค่าเริ่มต้นใน server action
  dueDate       DateTime
  paidAt        DateTime?

  subtotal      Decimal         @db.Decimal(12, 2)
  tax           Decimal         @db.Decimal(12, 2) @default(0)
  total         Decimal         @db.Decimal(12, 2)

  notes         String?         @db.Text

  payments      PaymentRecord[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
  @@index([dueDate])
  @@index([invoiceNumber])
}

model PaymentRecord {
  id          String        @id @default(cuid())

  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod @default(BANK_TRANSFER)
  reference   String?
  paidAt      DateTime      @default(now())
  note        String?

  createdAt   DateTime      @default(now())

  @@index([invoiceId])
  @@index([paidAt])
}

// --- Supplier Management Section (Phase 12) ---

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED
}

enum InboundShipmentStatus {
  IN_TRANSIT
  DELIVERED
  DELAYED
}

model Supplier {
  id            String           @id @default(cuid())
  name          String
  email         String?
  phone         String?
  address       String?          @db.Text
  contactPerson String?
  website       String?
  status        SupplierStatus   @default(ACTIVE)
  notes         String?          @db.Text

  purchaseOrders PurchaseOrder[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status])
  @@index([name])
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  // เลขที่ใบสั่งซื้อรูปแบบ PO-YYYYMM-XXXX
  poNumber        String              @unique

  supplierId      String
  supplier        Supplier            @relation(fields: [supplierId], references: [id])

  status          PurchaseOrderStatus @default(DRAFT)
  expectedDelivery DateTime?
  notes           String?             @db.Text

  subtotal        Decimal             @db.Decimal(12, 2) @default(0)
  total           Decimal             @db.Decimal(12, 2) @default(0)

  items           PurchaseOrderItem[]
  shipments       InboundShipment[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([supplierId])
  @@index([status])
  @@index([poNumber])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  productId       String
  product         Product       @relation(fields: [productId], references: [id])

  quantity        Int
  unitCost        Decimal       @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)

  @@index([purchaseOrderId])
  @@index([productId])
}

model InboundShipment {
  id              String                @id @default(cuid())

  purchaseOrderId String
  purchaseOrder   PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  trackingNumber  String?
  carrier         String?
  shippedAt       DateTime?
  receivedAt      DateTime?
  status          InboundShipmentStatus @default(IN_TRANSIT)

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([purchaseOrderId])
  @@index([status])
}

// --- Customer Management Section (Phase 13) ---

enum CustomerTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum CustomerStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model CustomerProfile {
  id              String          @id @default(cuid())

  // 1:1 กับ User
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName     String
  taxId           String?
  creditLimit     Decimal         @db.Decimal(12, 2) @default(0)
  creditUsed      Decimal         @db.Decimal(12, 2) @default(0)
  accountTier     CustomerTier    @default(BRONZE)
  status          CustomerStatus  @default(PENDING)

  billingAddress  String?         @db.Text
  shippingAddress String?         @db.Text
  notes           String?         @db.Text

  contacts        CustomerContact[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([accountTier])
  @@index([companyName])
}

model CustomerContact {
  id           String          @id @default(cuid())

  customerId   String
  customer     CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)

  name         String
  email        String?
  phone        String?
  role         String?
  isPrimary    Boolean         @default(false)

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([customerId])
}
// --- Notifications & Alerts Section (Phase 14) ---

enum NotificationType {
  LOW_STOCK
  OUT_OF_STOCK
  NEW_ORDER
  ORDER_STATUS_CHANGED
  INVOICE_OVERDUE
  SHIPMENT_UPDATE
  PURCHASE_ORDER_UPDATE
  SYSTEM
}

// --- User Approval & Audit Log Section (Phase 15) ---

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model UserApproval {
  id          String         @id @default(cuid())

  userId      String
  user        User           @relation("UserApprovals", fields: [userId], references: [id], onDelete: Cascade)

  status      ApprovalStatus @default(PENDING)

  // ผู้ admin ที่กดอนุมัติ/ปฏิเสธ (อาจเป็น null ตอน PENDING)
  reviewedBy  String?
  reviewer    User?          @relation("ApprovalReviewer", fields: [reviewedBy], references: [id])
  reviewedAt  DateTime?

  note        String?        @db.Text

  createdAt   DateTime       @default(now())

  @@index([userId])
  @@index([status])
  @@index([reviewedBy])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  action      String   // เช่น USER_APPROVED, ROLE_CHANGED, USER_SUSPENDED
  entity      String   // เช่น User, Order, Invoice
  entityId    String   // id ของ entity ที่ถูกกระทำ
  details     Json?    // metadata เพิ่มเติม เช่น from/to role
  ipAddress   String?

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  // ลิงก์ไปหน้าที่เกี่ยวข้อง (เช่น /merchant/orders/123)
  link      String?
  // metadata เก็บ context เพิ่มเติม เช่น orderId, invoiceId
  metadata  Json?

  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
}

// --- Settings & Configuration Section (Phase 16) ---

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

enum SettingCategory {
  GENERAL
  TAX
  CURRENCY
  WAREHOUSE
  EMAIL
  PRICING
}

model Setting {
  id          String          @id @default(cuid())
  // key เช่น tax.rate, store.name (unique เพื่อ upsert ได้)
  key         String          @unique
  // เก็บค่าเป็น String เสมอ แล้วใช้ type ระบุวิธี parse
  value       String          @db.Text
  type        SettingType     @default(STRING)
  category    SettingCategory @default(GENERAL)
  description String?         @db.Text

  // ผู้แก้ไขล่าสุด (optional เผื่อ system update)
  updatedBy   String?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([category])
  @@index([key])
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?  @db.Text
  city      String?
  country   String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  notes     String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isDefault])
  @@index([isActive])
  @@index([code])
}
