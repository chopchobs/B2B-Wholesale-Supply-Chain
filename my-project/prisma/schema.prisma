generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- User & RBAC Section ---
// NOTE: forward-declared so Order/User can reference Phase 17 outbound shipments.

enum Role {
  ADMIN
  MERCHANT
  VIP_CLIENT
  USER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          Role      @default(USER)
  isActive      Boolean   @default(true) // ซ่อน User ที่ถูกแบนได้
  
  managedShops  Shop[]    @relation("ShopOwner")
  orders        Order[]

  // Phase 13: ลูกค้า B2B ผูก 1:1 กับ User
  customerProfile CustomerProfile?

  // Phase 14: Notifications
  notifications Notification[]

  // Phase 15: User & Role Management
  approvals        UserApproval[] @relation("UserApprovals")
  reviewedApprovals UserApproval[] @relation("ApprovalReviewer")
  auditLogs        AuditLog[]

  // Phase 17: Outbound shipments ที่ผู้ใช้นี้สร้าง / จัดส่ง
  createdShipments Shipment[]     @relation("ShipmentCreator")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Shop {
  id          String    @id @default(cuid())
  name        String
  description String?
  isActive    Boolean   @default(true)
  
  ownerId     String
  owner       User      @relation("ShopOwner", fields: [ownerId], references: [id])
  products    Product[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// --- Product & Tiered Pricing Section ---

model Product {
  id          String      @id @default(cuid())
  sku         String      @unique
  name        String
  description String?     @db.Text
  basePrice   Decimal     @db.Decimal(12, 2)
  moq         Int         @default(1)
  stock       Int         @default(0)
  isActive    Boolean     @default(true) // Soft delete สินค้าได้
  
  shopId      String
  shop        Shop        @relation(fields: [shopId], references: [id])
  
  priceTiers  PriceTier[]
  orderItems  OrderItem[]
  
  category    Category?   @relation(fields: [categoryId], references: [id])
  categoryId  String?

  // Phase 9: เชื่อมกับ InventoryItem แบบ 1:1
  inventory   InventoryItem?

  // Phase 12: line items ใน PurchaseOrder
  purchaseOrderItems PurchaseOrderItem[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([shopId])
  @@index([sku])
  @@index([categoryId])
}

model PriceTier {
  id          String   @id @default(cuid())
  minQuantity Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  targetRole  Role     @default(VIP_CLIENT) 
  isActive    Boolean  @default(true) // เปิด/ปิด โปรโมชั่นขั้นบันไดได้
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// --- Category & Order Section ---

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  isActive    Boolean   @default(true)
  products    Product[]
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  totalAmount Decimal     @db.Decimal(12, 2)
  status      OrderStatus @default(PENDING)

  items       OrderItem[]

  // Phase 11: Invoice 1:1
  invoice     Invoice?

  // Phase 17: Shipments (1 order can have multiple split shipments)
  shipments   Shipment[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product  @relation(fields: [productId], references: [id])

  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  subTotal  Decimal  @db.Decimal(12, 2)

  // Phase 17: line items ใน outbound shipment (split shipment)
  shipmentItems ShipmentItem[]
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// --- Inventory Management Section (Phase 9) ---

model InventoryItem {
  id            String   @id @default(cuid())
  // ผูก 1:1 กับ Product ผ่าน productId
  productId     String   @unique
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // ปริมาณคงเหลือปัจจุบัน
  quantity      Int      @default(0)
  // เกณฑ์เตือนสต็อกต่ำ
  lowStockThreshold Int  @default(10)
  // คลัง / ตำแหน่งจัดเก็บ
  location      String   @default("MAIN-WH")

  transactions  InventoryTransaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([location])
}

enum InventoryTransactionType {
  RESTOCK
  SALE
  ADJUSTMENT
  RETURN
}

model InventoryTransaction {
  id          String   @id @default(cuid())

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  type        InventoryTransactionType
  // quantityDelta: บวก = เพิ่ม, ลบ = ลด (ADJUSTMENT/SALE ใช้ค่าลบได้)
  quantityDelta Int
  note        String?

  createdAt   DateTime @default(now())

  @@index([inventoryItemId])
  @@index([type])
  @@index([createdAt])
}

// --- Invoice & Billing Section (Phase 11) ---

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CREDIT
  CASH
}

model Invoice {
  id            String          @id @default(cuid())
  // เลขที่ใบแจ้งหนี้รูปแบบ INV-YYYYMM-XXXX
  invoiceNumber String          @unique

  // ผูก 1:1 กับ Order
  orderId       String          @unique
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status        InvoiceStatus   @default(DRAFT)
  issuedAt      DateTime        @default(now())
  // net 30 ตั้งค่าเริ่มต้นใน server action
  dueDate       DateTime
  paidAt        DateTime?

  subtotal      Decimal         @db.Decimal(12, 2)
  tax           Decimal         @db.Decimal(12, 2) @default(0)
  total         Decimal         @db.Decimal(12, 2)

  notes         String?         @db.Text

  payments      PaymentRecord[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
  @@index([dueDate])
  @@index([invoiceNumber])
}

model PaymentRecord {
  id          String        @id @default(cuid())

  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod @default(BANK_TRANSFER)
  reference   String?
  paidAt      DateTime      @default(now())
  note        String?

  createdAt   DateTime      @default(now())

  @@index([invoiceId])
  @@index([paidAt])
}

// --- Supplier Management Section (Phase 12) ---

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED
}

enum InboundShipmentStatus {
  IN_TRANSIT
  DELIVERED
  DELAYED
}

model Supplier {
  id            String           @id @default(cuid())
  name          String
  email         String?
  phone         String?
  address       String?          @db.Text
  contactPerson String?
  website       String?
  status        SupplierStatus   @default(ACTIVE)
  notes         String?          @db.Text

  purchaseOrders PurchaseOrder[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status])
  @@index([name])
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  // เลขที่ใบสั่งซื้อรูปแบบ PO-YYYYMM-XXXX
  poNumber        String              @unique

  supplierId      String
  supplier        Supplier            @relation(fields: [supplierId], references: [id])

  status          PurchaseOrderStatus @default(DRAFT)
  expectedDelivery DateTime?
  notes           String?             @db.Text

  subtotal        Decimal             @db.Decimal(12, 2) @default(0)
  total           Decimal             @db.Decimal(12, 2) @default(0)

  items           PurchaseOrderItem[]
  shipments       InboundShipment[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([supplierId])
  @@index([status])
  @@index([poNumber])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  productId       String
  product         Product       @relation(fields: [productId], references: [id])

  quantity        Int
  unitCost        Decimal       @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)

  @@index([purchaseOrderId])
  @@index([productId])
}

model InboundShipment {
  id              String                @id @default(cuid())

  purchaseOrderId String
  purchaseOrder   PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  trackingNumber  String?
  carrier         String?
  shippedAt       DateTime?
  receivedAt      DateTime?
  status          InboundShipmentStatus @default(IN_TRANSIT)

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([purchaseOrderId])
  @@index([status])
}

// --- Customer Management Section (Phase 13) ---

enum CustomerTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum CustomerStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model CustomerProfile {
  id              String          @id @default(cuid())

  // 1:1 กับ User
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName     String
  taxId           String?
  creditLimit     Decimal         @db.Decimal(12, 2) @default(0)
  creditUsed      Decimal         @db.Decimal(12, 2) @default(0)
  accountTier     CustomerTier    @default(BRONZE)
  status          CustomerStatus  @default(PENDING)

  billingAddress  String?         @db.Text
  shippingAddress String?         @db.Text
  notes           String?         @db.Text

  contacts        CustomerContact[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([accountTier])
  @@index([companyName])
}

model CustomerContact {
  id           String          @id @default(cuid())

  customerId   String
  customer     CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)

  name         String
  email        String?
  phone        String?
  role         String?
  isPrimary    Boolean         @default(false)

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([customerId])
}
// --- Notifications & Alerts Section (Phase 14) ---

enum NotificationType {
  LOW_STOCK
  OUT_OF_STOCK
  NEW_ORDER
  ORDER_STATUS_CHANGED
  INVOICE_OVERDUE
  SHIPMENT_UPDATE
  PURCHASE_ORDER_UPDATE
  SYSTEM
}

// --- User Approval & Audit Log Section (Phase 15) ---

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model UserApproval {
  id          String         @id @default(cuid())

  userId      String
  user        User           @relation("UserApprovals", fields: [userId], references: [id], onDelete: Cascade)

  status      ApprovalStatus @default(PENDING)

  // ผู้ admin ที่กดอนุมัติ/ปฏิเสธ (อาจเป็น null ตอน PENDING)
  reviewedBy  String?
  reviewer    User?          @relation("ApprovalReviewer", fields: [reviewedBy], references: [id])
  reviewedAt  DateTime?

  note        String?        @db.Text

  createdAt   DateTime       @default(now())

  @@index([userId])
  @@index([status])
  @@index([reviewedBy])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  action      String   // เช่น USER_APPROVED, ROLE_CHANGED, USER_SUSPENDED
  entity      String   // เช่น User, Order, Invoice
  entityId    String   // id ของ entity ที่ถูกกระทำ
  details     Json?    // metadata เพิ่มเติม เช่น from/to role
  ipAddress   String?

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  // ลิงก์ไปหน้าที่เกี่ยวข้อง (เช่น /merchant/orders/123)
  link      String?
  // metadata เก็บ context เพิ่มเติม เช่น orderId, invoiceId
  metadata  Json?

  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
}

// --- Settings & Configuration Section (Phase 16) ---

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

enum SettingCategory {
  GENERAL
  TAX
  CURRENCY
  WAREHOUSE
  EMAIL
  PRICING
}

model Setting {
  id          String          @id @default(cuid())
  // key เช่น tax.rate, store.name (unique เพื่อ upsert ได้)
  key         String          @unique
  // เก็บค่าเป็น String เสมอ แล้วใช้ type ระบุวิธี parse
  value       String          @db.Text
  type        SettingType     @default(STRING)
  category    SettingCategory @default(GENERAL)
  description String?         @db.Text

  // ผู้แก้ไขล่าสุด (optional เผื่อ system update)
  updatedBy   String?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([category])
  @@index([key])
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?  @db.Text
  city      String?
  country   String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  notes     String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isDefault])
  @@index([isActive])
  @@index([code])
}

// --- Shipping & Logistics Section (Phase 17) ---
// Outbound: Order → Customer (แยกจาก InboundShipment ใน Phase 12: Supplier → Warehouse)

enum CarrierStatus {
  ACTIVE
  INACTIVE
}

enum ShipmentStatus {
  PENDING        // สร้าง shipment แล้ว ยังไม่ได้ pick
  READY_TO_SHIP  // pack เสร็จ รอ pickup
  IN_TRANSIT     // carrier รับของแล้ว
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED         // ส่งไม่สำเร็จ
  RETURNED
  CANCELLED
}

enum ShipmentEventType {
  CREATED
  PICKED_UP
  IN_TRANSIT
  ARRIVED_AT_HUB
  OUT_FOR_DELIVERY
  DELIVERY_ATTEMPTED
  DELIVERED
  FAILED
  RETURNED
  CANCELLED
  NOTE
}

enum ShippingDocumentType {
  PACKING_SLIP
  SHIPPING_LABEL
  COMMERCIAL_INVOICE
  CUSTOMS_FORM
  OTHER
}

model Carrier {
  id            String         @id @default(cuid())
  // ชื่อผู้ให้บริการขนส่ง เช่น Kerry, Flash, ThaiPost
  name          String
  // code ใช้ในระบบ / generate tracking pattern (unique)
  code          String         @unique
  // URL template สำหรับติดตาม เช่น https://x.co/track?n={TRACKING}
  trackingUrl   String?        @db.Text
  contactName   String?
  contactPhone  String?
  contactEmail  String?
  status        CarrierStatus  @default(ACTIVE)
  notes         String?        @db.Text

  rates         ShippingRate[]
  shipments     Shipment[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([code])
}

model ShippingZone {
  id          String         @id @default(cuid())
  // เช่น "Bangkok Metro", "Central Thailand", "International"
  name        String         @unique
  // รายชื่อจังหวัด/รหัสไปรษณีย์/ประเทศ — เก็บเป็น JSON เพื่อความยืดหยุ่น
  regions     Json?
  description String?        @db.Text
  isActive    Boolean        @default(true)

  rates       ShippingRate[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([isActive])
}

model ShippingRate {
  id           String       @id @default(cuid())

  carrierId    String
  carrier      Carrier      @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  zoneId       String
  zone         ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  // service เช่น Standard, Express, Same-Day
  serviceName  String
  // ราคาตั้งต้น
  baseRate     Decimal      @db.Decimal(12, 2)
  // ราคา/กก. (ถ้า weight-based)
  perKgRate    Decimal      @db.Decimal(12, 2) @default(0)
  // น้ำหนักขั้นต่ำที่ baseRate ครอบคลุม (กก.)
  minWeightKg  Decimal      @db.Decimal(8, 3) @default(0)
  // ระยะเวลาส่งโดยประมาณ (วัน)
  estimatedDays Int?
  isActive     Boolean      @default(true)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([carrierId])
  @@index([zoneId])
  @@index([isActive])
  // ไม่ให้ซ้ำ service เดียวกันใน carrier+zone
  @@unique([carrierId, zoneId, serviceName])
}

model Shipment {
  id              String           @id @default(cuid())
  // เลขที่ shipment รูปแบบ SHP-YYYYMM-XXXX
  shipmentNumber  String           @unique

  orderId         String
  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  carrierId       String?
  carrier         Carrier?         @relation(fields: [carrierId], references: [id])

  // tracking จาก carrier (อาจยังไม่มีตอนสร้าง draft)
  trackingNumber  String?
  status          ShipmentStatus   @default(PENDING)

  // ค่าบริการขนส่งที่ลูกค้า/ร้านจ่าย (snapshot)
  shippingCost    Decimal          @db.Decimal(12, 2) @default(0)
  weightKg        Decimal          @db.Decimal(8, 3) @default(0)

  // ที่อยู่จัดส่ง (snapshot ตอนสร้าง — ไม่อ้างอิง CustomerProfile โดยตรง)
  shipToName      String
  shipToPhone     String?
  shipToAddress   String           @db.Text
  shipToCity      String?
  shipToPostal    String?
  shipToCountry   String?

  // ผู้สร้าง shipment (merchant/admin)
  createdById     String?
  createdBy       User?            @relation("ShipmentCreator", fields: [createdById], references: [id])

  shippedAt       DateTime?
  deliveredAt     DateTime?
  estimatedDelivery DateTime?

  notes           String?          @db.Text

  items           ShipmentItem[]
  events          ShipmentEvent[]
  documents       ShippingDocument[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([orderId])
  @@index([carrierId])
  @@index([status])
  @@index([trackingNumber])
  @@index([shipmentNumber])
  @@index([createdAt])
}

model ShipmentItem {
  id           String     @id @default(cuid())

  shipmentId   String
  shipment     Shipment   @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  // ผูกกับ OrderItem เพื่อรู้ว่า ship อะไรไปแล้วบ้าง
  orderItemId  String
  orderItem    OrderItem  @relation(fields: [orderItemId], references: [id])

  // จำนวนที่ส่งใน shipment นี้ (อาจ < orderItem.quantity ถ้า split)
  quantity     Int

  @@index([shipmentId])
  @@index([orderItemId])
}

model ShipmentEvent {
  id           String             @id @default(cuid())

  shipmentId   String
  shipment     Shipment           @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  type         ShipmentEventType
  // ข้อความเหตุการณ์ เช่น "Picked up at Bangkok hub"
  message      String             @db.Text
  // สถานที่ที่เกิดเหตุการณ์
  location     String?
  // เวลาที่เหตุการณ์เกิด (อาจไม่เท่ากับ createdAt ถ้า import จาก carrier)
  occurredAt   DateTime           @default(now())

  createdAt    DateTime           @default(now())

  @@index([shipmentId])
  @@index([type])
  @@index([occurredAt])
}

model ShippingDocument {
  id           String                @id @default(cuid())

  shipmentId   String
  shipment     Shipment              @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  type         ShippingDocumentType
  // URL/path ของไฟล์ที่ generate ออกมา (PDF/PNG) — อาจ null ถ้า render runtime
  fileUrl      String?               @db.Text
  // หมายเลขอ้างอิงเอกสาร เช่น PS-202605-0001
  documentNumber String?
  notes        String?               @db.Text

  createdAt    DateTime              @default(now())

  @@index([shipmentId])
  @@index([type])
}

