generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- User & RBAC Section ---

enum Role {
  ADMIN
  MERCHANT
  VIP_CLIENT
  USER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          Role      @default(USER)
  isActive      Boolean   @default(true) // ซ่อน User ที่ถูกแบนได้
  
  managedShops  Shop[]    @relation("ShopOwner")
  orders        Order[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Shop {
  id          String    @id @default(cuid())
  name        String
  description String?
  isActive    Boolean   @default(true)
  
  ownerId     String
  owner       User      @relation("ShopOwner", fields: [ownerId], references: [id])
  products    Product[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// --- Product & Tiered Pricing Section ---

model Product {
  id          String      @id @default(cuid())
  sku         String      @unique
  name        String
  description String?     @db.Text
  basePrice   Decimal     @db.Decimal(12, 2)
  moq         Int         @default(1)
  stock       Int         @default(0)
  isActive    Boolean     @default(true) // Soft delete สินค้าได้
  
  shopId      String
  shop        Shop        @relation(fields: [shopId], references: [id])
  
  priceTiers  PriceTier[]
  orderItems  OrderItem[]
  
  category    Category?   @relation(fields: [categoryId], references: [id])
  categoryId  String?

  // Phase 9: เชื่อมกับ InventoryItem แบบ 1:1
  inventory   InventoryItem?

  // Phase 12: line items ใน PurchaseOrder
  purchaseOrderItems PurchaseOrderItem[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([shopId])
  @@index([sku])
  @@index([categoryId])
}

model PriceTier {
  id          String   @id @default(cuid())
  minQuantity Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  targetRole  Role     @default(VIP_CLIENT) 
  isActive    Boolean  @default(true) // เปิด/ปิด โปรโมชั่นขั้นบันไดได้
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// --- Category & Order Section ---

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  isActive    Boolean   @default(true)
  products    Product[]
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  totalAmount Decimal     @db.Decimal(12, 2)
  status      OrderStatus @default(PENDING)

  items       OrderItem[]

  // Phase 11: Invoice 1:1
  invoice     Invoice?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  subTotal  Decimal  @db.Decimal(12, 2)
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// --- Inventory Management Section (Phase 9) ---

model InventoryItem {
  id            String   @id @default(cuid())
  // ผูก 1:1 กับ Product ผ่าน productId
  productId     String   @unique
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // ปริมาณคงเหลือปัจจุบัน
  quantity      Int      @default(0)
  // เกณฑ์เตือนสต็อกต่ำ
  lowStockThreshold Int  @default(10)
  // คลัง / ตำแหน่งจัดเก็บ
  location      String   @default("MAIN-WH")

  transactions  InventoryTransaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([location])
}

enum InventoryTransactionType {
  RESTOCK
  SALE
  ADJUSTMENT
  RETURN
}

model InventoryTransaction {
  id          String   @id @default(cuid())

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  type        InventoryTransactionType
  // quantityDelta: บวก = เพิ่ม, ลบ = ลด (ADJUSTMENT/SALE ใช้ค่าลบได้)
  quantityDelta Int
  note        String?

  createdAt   DateTime @default(now())

  @@index([inventoryItemId])
  @@index([type])
  @@index([createdAt])
}

// --- Invoice & Billing Section (Phase 11) ---

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CREDIT
  CASH
}

model Invoice {
  id            String          @id @default(cuid())
  // เลขที่ใบแจ้งหนี้รูปแบบ INV-YYYYMM-XXXX
  invoiceNumber String          @unique

  // ผูก 1:1 กับ Order
  orderId       String          @unique
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status        InvoiceStatus   @default(DRAFT)
  issuedAt      DateTime        @default(now())
  // net 30 ตั้งค่าเริ่มต้นใน server action
  dueDate       DateTime
  paidAt        DateTime?

  subtotal      Decimal         @db.Decimal(12, 2)
  tax           Decimal         @db.Decimal(12, 2) @default(0)
  total         Decimal         @db.Decimal(12, 2)

  notes         String?         @db.Text

  payments      PaymentRecord[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
  @@index([dueDate])
  @@index([invoiceNumber])
}

model PaymentRecord {
  id          String        @id @default(cuid())

  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod @default(BANK_TRANSFER)
  reference   String?
  paidAt      DateTime      @default(now())
  note        String?

  createdAt   DateTime      @default(now())

  @@index([invoiceId])
  @@index([paidAt])
}

// --- Supplier Management Section (Phase 12) ---

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED
}

enum InboundShipmentStatus {
  IN_TRANSIT
  DELIVERED
  DELAYED
}

model Supplier {
  id            String           @id @default(cuid())
  name          String
  email         String?
  phone         String?
  address       String?          @db.Text
  contactPerson String?
  website       String?
  status        SupplierStatus   @default(ACTIVE)
  notes         String?          @db.Text

  purchaseOrders PurchaseOrder[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status])
  @@index([name])
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  // เลขที่ใบสั่งซื้อรูปแบบ PO-YYYYMM-XXXX
  poNumber        String              @unique

  supplierId      String
  supplier        Supplier            @relation(fields: [supplierId], references: [id])

  status          PurchaseOrderStatus @default(DRAFT)
  expectedDelivery DateTime?
  notes           String?             @db.Text

  subtotal        Decimal             @db.Decimal(12, 2) @default(0)
  total           Decimal             @db.Decimal(12, 2) @default(0)

  items           PurchaseOrderItem[]
  shipments       InboundShipment[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([supplierId])
  @@index([status])
  @@index([poNumber])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  productId       String
  product         Product       @relation(fields: [productId], references: [id])

  quantity        Int
  unitCost        Decimal       @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)

  @@index([purchaseOrderId])
  @@index([productId])
}

model InboundShipment {
  id              String                @id @default(cuid())

  purchaseOrderId String
  purchaseOrder   PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  trackingNumber  String?
  carrier         String?
  shippedAt       DateTime?
  receivedAt      DateTime?
  status          InboundShipmentStatus @default(IN_TRANSIT)

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([purchaseOrderId])
  @@index([status])
}